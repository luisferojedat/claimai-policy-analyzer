        "\n",
        "# ------------------------------------------------------------\n",
        "# 6. Confirmación final\n",
        "# ------------------------------------------------------------\n",
        "\n",
        "print(\"\\nListo para ejecutar la sección 6.1.\")\n",
        "print(\"best_model_name:\", best_model_name)\n",
        "print(\"best_model_pipeline:\", best_model_pipeline)"
