        "\n",
        "    # Compatibilidad con nombres de columnas distintos\n",
        "    if \"F1-score\" not in results_df.columns and \"F1-Score\" in results_df.columns:\n",
        "        results_df = results_df.rename(columns={\"F1-Score\": \"F1-score\"})\n",
        "\n",
        "    sort_cols = []\n",
